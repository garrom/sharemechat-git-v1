<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap del SPA publico.
  Incluye paginas estaticas (home + secciones legales/info) y las dos
  rutas raiz del blog por locale. Las URLs concretas de articulos NO
  se listan aqui hoy porque la DB de PROD no tiene articulos publicados
  (verificado 2026-06-06 via /api/public/content/articles -> items: []).
  Cuando se publiquen, regenerar este fichero (script de prerender de
  blog o tarea manual) anadiendo <url><loc>...</loc></url> por cada
  articulo en cada locale, idealmente con <lastmod> y <changefreq>.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <url>
    <loc>https://sharemechat.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://sharemechat.com/blog/es</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    <xhtml:link rel="alternate" hreflang="es" href="https://sharemechat.com/blog/es"/>
    <xhtml:link rel="alternate" hreflang="en" href="https://sharemechat.com/blog/en"/>
  </url>

  <url>
    <loc>https://sharemechat.com/blog/en</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
    <xhtml:link rel="alternate" hreflang="es" href="https://sharemechat.com/blog/es"/>
    <xhtml:link rel="alternate" hreflang="en" href="https://sharemechat.com/blog/en"/>
  </url>

  <url>
    <loc>https://sharemechat.com/legal</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>

  <url>
    <loc>https://sharemechat.com/faq</loc>
