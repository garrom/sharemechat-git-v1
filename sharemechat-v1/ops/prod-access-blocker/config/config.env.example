# Bloqueador (Carril A real) de accesos de PROD
# Copiar a /etc/sharemechat-prod-access-blocker/config.env
#
# IMPORTANTE: este componente esta en CARRIL-A REAL.
# - SI escribe /etc/nginx/deny-prod-ips.conf cuando hay nuevas IPs.
# - SI ejecuta nginx -t pre/post y reload tras nginx -t OK.
# - Backup automatico .bak_<ts> antes de cada cambio.
# - Para volver a DRY-RUN: DRY_RUN=1 abajo.

PYTHON_BIN=python3

# Directorios operativos
WORK_ROOT=/var/lib/sharemechat-prod-access-blocker
OUTPUT_ROOT=/var/log/sharemechat-prod-access-blocker

# Entrada: salida del clasificador existente (summary.jsonl diario)
CLASSIFIER_OUTPUT_ROOT=/var/log/sharemechat-prod-access-classifier

# Estado persistente (historial por IP, TTLs, ventana deslizante)
STATE_FILE=/var/lib/sharemechat-prod-access-blocker/ips.json

# Allowlist (opcional)
# Formato ALLOWLIST_IPS: IPs o CIDR separados por coma
# ALLOWLIST_IPS=198.51.100.10,203.0.113.0/24
ALLOWLIST_IPS=
# Formato ALLOWLIST_FILE: una IP o CIDR por linea, comentarios con '#'
ALLOWLIST_FILE=/etc/sharemechat-prod-access-blocker/allowlist.conf

# TTLs y ventana (dias)
CARRIL_A_TTL_DAYS=30
CARRIL_B_TTL_DAYS=14
CARRIL_B_WINDOW_DAYS=7

# Carril A real. DRY_RUN=1 si necesitas reactivar modo observacion.
DRY_RUN=0

# Fichero live que usa nginx
NGINX_DENY_FILE=/etc/nginx/deny-prod-ips.conf

# Fichero manual
NGINX_MANUAL_DENY_FILE=/etc/nginx/deny-prod-ips.manual.conf
