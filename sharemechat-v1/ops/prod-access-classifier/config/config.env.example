# Clasificador de accesos de PROD
# Copiar a /etc/sharemechat-prod-access-classifier/config.env

PYTHON_BIN=python3

# Directorios
WORK_ROOT=/var/lib/sharemechat-prod-access-classifier
OUTPUT_ROOT=/var/log/sharemechat-prod-access-classifier

# Entrada: salida canónica del normalizador existente
NORMALIZED_ROOT=/var/log/sharemechat-prod-access-normalizer

# Opcional: IPs permitidas/esperadas para bajar scoring
# Formato de ejemplo:
# ALLOWLIST_IPS=198.51.100.10,198.51.100.11
ALLOWLIST_IPS=90.175.201.51

# Opcional: fichero con una IP por línea
ALLOWLIST_FILE=
