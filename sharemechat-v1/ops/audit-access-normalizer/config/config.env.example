# Normalizador de accesos de AUDIT
# Copiar a /etc/sharemechat-audit-access-normalizer/config.env

AWS_BIN=aws
PYTHON_BIN=python3

# Estado y trabajo interno
WORK_ROOT=/var/lib/sharemechat-audit-access-normalizer
STATE_ROOT=/var/lib/sharemechat-audit-access-normalizer/state
TMP_ROOT=/var/lib/sharemechat-audit-access-normalizer/tmp
CHUNK_ROOT=/var/lib/sharemechat-audit-access-normalizer/chunks

# Salida canónica diaria JSONL
OUTPUT_ROOT=/var/log/sharemechat-audit-access-normalizer

# Fuentes
CF_BUCKET=sharemechat-cf-logs-audit
CF_PREFIX_AUDIT=cloudfront/audit/
CF_PREFIX_ADMIN=cloudfront/admin-audit/
NGINX_ACCESS_LOG=/var/log/nginx/access.log

# El parser de Nginx soporta:
# - combined estándar
# - variante con host como primer campo (vhost combined)
# Si el formato real del access.log del host difiere, este dato debe ajustarse
# fuera del repo antes de activar el servicio.
