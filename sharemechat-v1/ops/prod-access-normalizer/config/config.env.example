# Normalizador de accesos de PROD
# Copiar a /etc/sharemechat-prod-access-normalizer/config.env

AWS_BIN=aws
PYTHON_BIN=python3

# Estado y trabajo interno
WORK_ROOT=/var/lib/sharemechat-prod-access-normalizer
STATE_ROOT=/var/lib/sharemechat-prod-access-normalizer/state
TMP_ROOT=/var/lib/sharemechat-prod-access-normalizer/tmp
CHUNK_ROOT=/var/lib/sharemechat-prod-access-normalizer/chunks

# Salida canónica diaria JSONL
OUTPUT_ROOT=/var/log/sharemechat-prod-access-normalizer

# Fuentes
CF_BUCKET=sharemechat-cf-logs-prod
CF_PREFIX_PRODUCT=product/
CF_PREFIX_ADMIN=admin/
NGINX_ACCESS_LOG=/var/log/nginx/api.sharemechat.access.log

# El parser de Nginx soporta:
# - combined estándar
# - variante con host como primer campo (vhost combined)
# Si el formato real del access.log del host difiere, este dato debe ajustarse
# fuera del repo antes de activar el servicio.
