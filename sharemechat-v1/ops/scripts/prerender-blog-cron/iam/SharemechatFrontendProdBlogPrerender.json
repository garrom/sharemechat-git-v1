{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteFrontendProdBlogPrefix",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:DeleteObject", "s3:GetObject", "s3:HeadObject"],
      "Resource": "arn:aws:s3:::sharemechat-frontend-prod/blog/*"
    },
    {
      "Sid": "ListFrontendProdForSync",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::sharemechat-frontend-prod",
      "Condition": {"StringLike": {"s3:prefix": ["blog/*", "blog"]}}
    },
    {
      "Sid": "InvalidateBlogPaths",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::430118829334:distribution/E2FWNC80D4QDJC"
    }
  ]
}
