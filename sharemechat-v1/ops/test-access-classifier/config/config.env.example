# Clasificador de accesos de TEST
# Copiar a /etc/sharemechat-test-access-classifier/config.env

PYTHON_BIN=python3

# Directorios
WORK_ROOT=/var/lib/sharemechat-test-access-classifier
OUTPUT_ROOT=/var/log/sharemechat-test-access-classifier

# Entrada: salida canónica del normalizador de TEST
NORMALIZED_ROOT=/var/log/sharemechat-test-access-normalizer

# Opcional: IPs permitidas/esperadas para bajar scoring
# Formato de ejemplo:
# ALLOWLIST_IPS=198.51.100.10,198.51.100.11
ALLOWLIST_IPS=

# Opcional: fichero con una IP por línea
ALLOWLIST_FILE=
