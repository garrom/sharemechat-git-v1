# Reporter de accesos de PROD
# Copiar a /etc/sharemechat-prod-access-reporter/config.env

PYTHON_BIN=python3

# Entrada: salida del clasificador existente
CLASSIFIER_OUTPUT_ROOT=/var/log/sharemechat-prod-access-classifier

# Salida: reportes diarios generados manualmente
OUTPUT_ROOT=/var/log/sharemechat-prod-access-reporter

# SMTP manual para envio opcional del reporte diario
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=30
EMAIL_FROM=
EMAIL_TO=
