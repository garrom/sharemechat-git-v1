# Normalizador de accesos de TEST
# Copiar a /etc/sharemechat-test-access-normalizer/config.env

AWS_BIN=aws
PYTHON_BIN=python3

# Estado y trabajo interno
WORK_ROOT=/var/lib/sharemechat-test-access-normalizer
STATE_ROOT=/var/lib/sharemechat-test-access-normalizer/state
TMP_ROOT=/var/lib/sharemechat-test-access-normalizer/tmp
CHUNK_ROOT=/var/lib/sharemechat-test-access-normalizer/chunks

# Salida canónica diaria JSONL
OUTPUT_ROOT=/var/log/sharemechat-test-access-normalizer

# Fuente Nginx
# El vhost api.test.sharemechat.com escribe en este fichero cuando
# access_log está configurado con un formato personalizado.
# Con el vhost actual (formato main global), usar /var/log/nginx/access.log.
NGINX_ACCESS_LOG=/var/log/nginx/api.test.access.log

# Fuente CloudFront (opcional)
# Si CF_BUCKET está vacío, el componente funciona solo con Nginx.
# Activar cuando el logging de CF esté habilitado en la distribución TEST
# y el bucket sharemechat-cf-logs-test esté creado y accesible.
CF_BUCKET=
CF_PREFIX_FRONTEND=
CF_PREFIX_ADMIN=
