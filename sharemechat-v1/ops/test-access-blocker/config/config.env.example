# Bloqueador de accesos de TEST
# Copiar a /etc/sharemechat-test-access-blocker/config.env

PYTHON_BIN=python3

# Directorios operativos
WORK_ROOT=/var/lib/sharemechat-test-access-blocker
OUTPUT_ROOT=/var/log/sharemechat-test-access-blocker

# Entrada: salida del clasificador de TEST (summary.jsonl diario)
CLASSIFIER_OUTPUT_ROOT=/var/log/sharemechat-test-access-classifier

# Estado persistente (historial por IP, TTLs, ventana deslizante)
STATE_FILE=/var/lib/sharemechat-test-access-blocker/ips.json

# Allowlist (opcional)
# Formato ALLOWLIST_IPS: IPs o CIDR separados por coma
# ALLOWLIST_IPS=198.51.100.10,203.0.113.0/24
ALLOWLIST_IPS=
# Formato ALLOWLIST_FILE: una IP o CIDR por linea, comentarios con '#'
ALLOWLIST_FILE=/etc/sharemechat-test-access-blocker/allowlist.conf

# TTLs y ventana (dias) - iguales que AUDIT para misma politica
CARRIL_A_TTL_DAYS=30
CARRIL_B_TTL_DAYS=14
CARRIL_B_WINDOW_DAYS=7

# Modo de operacion:
#   DRY_RUN=1  -> solo propuesta advisory; NO toca nginx en absoluto (default seguro)
#   DRY_RUN=0  -> aplica bloqueo REAL en nginx EXCLUSIVAMENTE para Carril A;
#                 Carril B y Carril C siguen siendo solo propuesta
#
# En TEST, DRY_RUN=0 NO se activa hasta completar el checklist del README:
#   1. Desplegar el componente en EC2 TEST y validar DRY-RUN durante >=14 dias
#   2. Confirmar allowlist actualizada (testers internos, QA, VPN, uptime checks)
#   3. Confirmar que /etc/nginx/deny-test-ips.conf existe con el include en nginx
#   4. Ejecutar manualmente una vez con DRY_RUN=0 y revisar diff y journalctl
DRY_RUN=1

# Ruta del fichero live de deny list en nginx.
# Solo se usa cuando DRY_RUN=0. Debe coincidir con el include en el config de nginx.
# En DRY_RUN=1 esta variable no tiene efecto.
NGINX_DENY_FILE=/etc/nginx/deny-test-ips.conf

# Fichero de bloqueos manuales (solo lectura).
# Si existe, sus entradas se preservan en el fichero live por encima del bloque
# auto-generado. Las IPs ya presentes en el manual no se duplican en el bloque
# de Carril A. Si no existe, el blocker continua sin fallar.
# Este fichero NUNCA se modifica por el componente.
NGINX_MANUAL_DENY_FILE=/etc/nginx/deny-test-ips.manual.conf
